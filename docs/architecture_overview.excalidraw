    {
      "id": "debug-flow-v1-text",
      "type": "text",
      "x": 5354.966207837302,
      "y": 371.6348896329364,
      "width": 1180,
      "height": 470,
      "angle": 0,
      "strokeColor": "#d3d1c7",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "UbYBGkq2BNaClqvXR4pyG"
      ],
      "frameId": null,
      "index": "ay",
