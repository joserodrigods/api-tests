							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200 - Card criado com sucesso\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"ID do card não está vazio\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.id).to.not.be.empty;",
									"    pm.environment.set(\"card_id\", json.id);",
									"});",
									"",
									"pm.test(\"Nome do card está correto\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.name).to.equal(\"Card de Teste - Automação QA\");",
									"});",
									"",
									"pm.test(\"Card está na lista correta\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.idList).to.equal(pm.environment.get(\"list_todo_id\"));",
									"});"
