{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Cucumber: All features",
      "program": "${workspaceFolder}/node_modules/@cucumber/cucumber/bin/cucumber.js",
      "args": [
        "--config",
        "cucumber.js"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
